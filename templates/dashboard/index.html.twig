{% extends 'base.html.twig' %}

{% block title %}Tableau de bord - Gestion de Tâches{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-[#f8f9fa]">
    
    {# --- SIDEBAR GAUCHE --- #}
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-6">
            <div class="flex items-center gap-2 px-4 py-3 bg-[#0a0a14] text-white rounded-xl cursor-pointer">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                <span class="font-medium text-sm">Toutes les tâches</span>
            </div>
        </div>

        <nav class="flex-1 px-6">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">Dossiers</h3>
            <div class="space-y-1">
                <div class="flex items-center justify-between px-4 py-2 hover:bg-gray-100 rounded-lg cursor-pointer group">
                    <div class="flex items-center gap-3">
                        <div class="w-3 h-3 bg-green-500 rounded-sm"></div>
                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
                        <span class="text-sm font-medium text-gray-700">Maison</span>
                    </div>
                    <span class="text-xs text-gray-400 group-hover:text-gray-600">1</span>
                </div>
            </div>
        </nav>
    </aside>

    {# --- CONTENU PRINCIPAL --- #}
    <main class="flex-1 flex flex-col">
        
        {# Barre de navigation haute #}
        <header class="h-20 bg-white border-b border-gray-100 flex items-center justify-between px-8">
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Gestion de Tâches</h1>
                <p class="text-xs text-gray-400">Organisez votre journée efficacement</p>
            </div>
            
            <div class="flex items-center gap-3">
                <button class="flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 rounded-lg transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path></svg>
                    Gérer les priorités
                </button>
                <button class="flex items-center gap-2 border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path></svg>
                    Nouveau dossier
                </button>
                <button class="flex items-center gap-2 bg-[#0a0a14] text-white px-4 py-2 text-sm font-bold rounded-lg hover:bg-gray-800 transition shadow-sm">
                    <span class="text-lg">+</span> Nouvelle tâche
                </button>
                <a href="{{ logout_path() }}" class="flex items-center gap-2 border border-gray-200 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Déconnexion
                </a>
            </div>
        </header>

        {# Zone de filtres #}
        <div class="px-8 py-4 flex items-center gap-8 text-sm border-b border-gray-100 bg-white">
            <div class="flex items-center gap-2 text-gray-500">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
                Filtres :
            </div>
            <div class="flex items-center gap-2">
                <span class="text-gray-400">Statut</span>
                <select class="bg-gray-100 border-none rounded-lg px-3 py-1 text-xs font-bold text-gray-700 outline-none">
                    <option>Tous</option>
                </select>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-gray-400">Priorité</span>
                <select class="bg-gray-100 border-none rounded-lg px-3 py-1 text-xs font-bold text-gray-700 outline-none">
                    <option>Toutes</option>
                </select>
            </div>
        </div>

        {# Liste des tâches #}
        <div class="flex-1 p-8 space-y-4 overflow-y-auto">
            
            {% if tasks|length == 0 %}
                <div class="text-center py-12">
                    <p class="text-gray-400">Aucune tâche pour le moment. Créez-en une ! </p>
                </div>
            {% else %}
                {% for task in tasks %}
            <div class="bg-white border border-gray-100 rounded-2xl p-5 flex items-center justify-between hover:shadow-md transition-shadow cursor-pointer group">
                <div class="flex items-center gap-4">
                    <input type="checkbox" class="w-5 h-5 rounded-md border-gray-200 text-blue-500 focus:ring-blue-500">
                    <div>
                        <div class="flex items-center gap-3">
                            <h4 class="font-bold text-gray-800">{{ task.title }}</h4>
                            {% if task.priority %}
                                <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase 
                                    {% if task.priority.level == 'urgent' %} bg-red-100 text-red-500
                                    {% elseif task.priority.level == 'important' %} bg-orange-100 text-orange-500
                                    {% else %} bg-blue-100 text-blue-500 {% endif %}">
                                    {{ task.priority.level }}
                                </span>
                            {% endif %}
                        </div>
                        <p class="text-xs text-gray-400 mt-1">
                            {% if task.status.value == 'pending' %}
                                En cours
                            {% elseif task.status.value == 'completed' %}
                                Terminée
                            {% elseif task.status.value == 'archived' %}
                                Archivée
                            {% endif %}
                        </p>
                    </div>
                </div>
                <button class="text-gray-300 group-hover:text-gray-500 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"></path></svg>
                </button>
            </div>
            {% endfor %}
            {% endif %}

        </div>
    </main>
</div>
{% endblock %}