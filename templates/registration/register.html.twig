{% extends 'base.html.twig' %}

{% block title %}Inscription - Gestion de Tâches{% endblock %}

{% block body %}
<div class="min-h-screen bg-blue-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-[2rem] shadow-2xl p-10 w-full max-w-md border border-white/50">
        
        {# En-tête #}
        <div class="mb-8 text-center sm:text-left">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Gestion de Tâches</h1>
            <p class="text-gray-500 text-sm mt-2">Organisez votre journée efficacement </p>
        </div>

        {# Sélecteur Connexion/Inscription #}
        <div class="flex bg-gray-100 p-1.5 rounded-2xl mb-8">
            <a href="{{ path('app_login') }}" class="w-1/2 text-center py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-700 transition">Connexion</a>
            <div class="w-1/2 text-center py-2.5 text-sm font bg-white rounded-xl shadow-sm text-600">Inscription</div>
        </div>

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-4'}}) }}
            
         

            {# Champ Email #}
            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700 ml-1">Email</label>
                {{ form_widget(registrationForm.email, {
                    'attr': {
                        'class': 'w-full px-5 py-4 bg-gray-50 border-transparent rounded-2xl focus:bg-white focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all placeholder-gray-400 outline-none',
                        'placeholder': 'votre@email.com'
                    }
                }) }}
                <div class="text-red-500 text-xs font-medium mt-1">{{ form_errors(registrationForm.email) }}</div>
            </div>
   {# Champ Nom d'utilisateur (Ajouté ici) #}
            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700 ml-1">Nom d'utilisateur</label>
                {{ form_widget(registrationForm.username, {
                    'attr': {
                        'class': 'w-full px-5 py-4 bg-gray-50 border-transparent rounded-2xl focus:bg-white focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all placeholder-gray-400 outline-none',
                        'placeholder': 'ex: Jean Dupont'
                    }
                }) }}
                <div class="text-red-500 text-xs font-medium mt-1">{{ form_errors(registrationForm.username) }}</div>
            </div>
            {# Champ Mot de passe #}
            <div class="space-y-1">
                <label class="block text-sm font-bold text-gray-700 ml-1">Mot de passe</label>
                {{ form_widget(registrationForm.plainPassword, {
                    'attr': {
                        'class': 'w-full px-5 py-4 bg-gray-50 border-transparent rounded-2xl focus:bg-white focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all placeholder-gray-400 outline-none',
                        'placeholder': '••••••••'
                    }
                }) }}
                <div class="text-red-500 text-xs font-medium mt-1">{{ form_errors(registrationForm.plainPassword) }}</div>
            </div>

            {# Checkbox Termes #}
            <div class="flex items-center gap-3 py-2 px-1">
                {{ form_widget(registrationForm.agreeTerms, {
                    'attr': {'class': 'w-5 h-5 rounded-md border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer'}
                }) }}
                <label class="text-xs text-gray-500 leading-tight">
                    J'accepte les <span class="text-blue-600 font-semibold cursor-pointer">conditions d'utilisation</span>
                </label>
            </div>

            {# Bouton de soumission #}
            <button type="submit" class="w-full bg-[#0a0a14] text-white font-bold py-4 rounded-2xl hover:bg-gray-800 hover:scale-[1.01] active:scale-95 transition-all duration-200 shadow-lg shadow-gray-200 mt-2">
                S'inscrire
            </button>

        {{ form_end(registrationForm) }}

    </div>
</div>
{% endblock %}